{
  "name": "solstice-wave-festival",
  "description": "Demo festival site: Astro + SQLite (Cloudflare D1) with VIP/Admin gating via a pretend delegate login",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:migrate && astro dev",
    "build": "astro build",
    "preview": "astro build && wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply festival-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply festival-db --remote",
    "db:reset": "rm -rf .wrangler/state && npm run db:migrate",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "@engine9/client": "file:../client",
    "astro": "^7.0.6",
    "wrangler": "^4.107.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3"
  }
}
