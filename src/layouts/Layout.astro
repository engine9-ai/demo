---
import { canAccessVip, isAdmin, primaryRole } from "../lib/session";

interface Props {
  title: string;
}
const { title } = Astro.props;
const session = Astro.locals.session;
const path = Astro.url.pathname;
const isAdminRoute = path.startsWith("/admin");

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/lineup", label: "Lineup" },
  { href: "/schedule", label: "Schedule" },
  { href: "/tickets", label: "Tickets" },
  { href: "/register", label: "Register" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Solstice Wave Festival</title>
    <meta name="description" content="Solstice Wave — two days of pop on the Crescent Bay waterfront. Demo site." />
  </head>
  <body class:list={{ "admin-route": isAdminRoute }}>
    <header class="site-header">
      <a class="wordmark" href="/">SOLSTICE<span>WAVE</span></a>
      <nav>
        {navLinks.map((l) => (
          <a href={l.href} class:list={{ active: path === l.href }}>{l.label}</a>
        ))}
        {canAccessVip(session) && (
          <a href="/vip" class:list={["vip-link", { active: path.startsWith("/vip") }]}>VIP Lounge</a>
        )}
        {isAdmin(session) && (
          <a href="/admin" class:list={["admin-link", { active: path.startsWith("/admin") }]}>Admin</a>
        )}
      </nav>
      <div class="session-box">
        {session ? (
          <>
            <span
              class:list={["badge", primaryRole(session)]}
              title={session.auth?.signInProvider
                ? `via delegate · ${session.auth.signInProvider}${session.auth.twoFactor ? " · 2FA" : ""}`
                : "via delegate"}
            >{primaryRole(session).toUpperCase()}</span>
            <form method="post" action="/auth/logout">
              <button class="btn btn-ghost" type="submit">Log out</button>
            </form>
          </>
        ) : (
          <a class="btn btn-ghost" href="/login">Log in</a>
        )}
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>Solstice Wave Festival · Crescent Bay Waterfront · July 18–19, 2026</p>
      <p class="fine">
        Demo site. Authentication is handled by the shared
        <strong>delegate</strong> service; access levels are this site's own
        segments.
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0d0a1f;
    --surface: #171233;
    --surface-2: #1f1946;
    --border: #322a63;
    --text: #f1eeff;
    --muted: #a79fd1;
    --primary: #a855f7;
    --accent: #f472b6;
    --sun: #fbbf24;
    --vip: #fbbf24;
    --admin: #34d399;
    --grad: linear-gradient(120deg, #a855f7, #f472b6 55%, #fbbf24);
    --radius: 14px;
    --font: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: var(--font);
    background:
      radial-gradient(1200px 500px at 80% -10%, rgba(168, 85, 247, 0.25), transparent 60%),
      radial-gradient(900px 400px at 10% 0%, rgba(244, 114, 182, 0.18), transparent 60%),
      var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  body.admin-route {
    background: #000;
  }

  body.admin-route .site-header {
    background: rgba(0, 0, 0, 0.85);
  }

  main { flex: 1; width: min(1060px, 92vw); margin: 0 auto; padding: 2.5rem 0 4rem; }

  h1, h2, h3 { line-height: 1.15; letter-spacing: -0.02em; }
  h1 { font-size: clamp(2.2rem, 5.5vw, 3.6rem); font-weight: 800; margin: 0 0 0.5rem; }
  h2 { font-size: 1.6rem; font-weight: 750; margin: 2.5rem 0 1rem; }
  p { line-height: 1.6; }
  a { color: var(--accent); }

  .gradient-text {
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .site-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: 1rem clamp(1rem, 4vw, 2.5rem);
    border-bottom: 1px solid var(--border);
    background: rgba(13, 10, 31, 0.8);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .wordmark {
    font-weight: 900;
    font-size: 1.25rem;
    letter-spacing: 0.06em;
    color: var(--text);
    text-decoration: none;
  }
  .wordmark span {
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .site-header nav { display: flex; gap: 0.25rem; flex-wrap: wrap; }
  .site-header nav a {
    color: var(--muted);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .site-header nav a:hover { color: var(--text); background: var(--surface-2); }
  .site-header nav a.active { color: var(--text); background: var(--surface-2); }
  .site-header nav a.vip-link { color: var(--vip); }
  .site-header nav a.admin-link { color: var(--admin); }

  .session-box { margin-left: auto; display: flex; align-items: center; gap: 0.6rem; }
  .session-box form { margin: 0; }

  .badge {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }
  .badge.vip { background: rgba(251, 191, 36, 0.15); color: var(--vip); border: 1px solid rgba(251, 191, 36, 0.4); }
  .badge.admin { background: rgba(52, 211, 153, 0.15); color: var(--admin); border: 1px solid rgba(52, 211, 153, 0.4); }
  .badge.member { background: rgba(168, 85, 247, 0.15); color: var(--primary); border: 1px solid rgba(168, 85, 247, 0.4); }

  .btn {
    display: inline-block;
    font: inherit;
    font-weight: 700;
    padding: 0.6rem 1.3rem;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    color: white;
  }
  .btn-primary { background: var(--grad); }
  .btn-primary:hover { filter: brightness(1.1); }
  .btn-ghost {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.45rem 1rem;
    font-size: 0.9rem;
  }
  .btn-ghost:hover { background: var(--surface-2); }
  .btn-danger { background: #be123c; font-size: 0.8rem; padding: 0.35rem 0.8rem; }
  .btn-danger:hover { filter: brightness(1.15); }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
  }

  .grid { display: grid; gap: 1rem; }
  @media (min-width: 720px) {
    .grid-2 { grid-template-columns: 1fr 1fr; }
    .grid-3 { grid-template-columns: repeat(3, 1fr); }
  }

  table { width: 100%; border-collapse: collapse; }
  th, td { text-align: left; padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--border); }
  th { color: var(--muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; }

  input, select, textarea {
    font: inherit;
    color: var(--text);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.7rem;
    width: 100%;
  }
  label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--muted); margin-bottom: 0.3rem; }
  .field { margin-bottom: 0.9rem; }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem clamp(1rem, 4vw, 2.5rem);
    color: var(--muted);
    font-size: 0.9rem;
  }
  .site-footer .fine { font-size: 0.8rem; opacity: 0.8; }
  .site-footer p { margin: 0.25rem 0; }

  .muted { color: var(--muted); }
</style>
