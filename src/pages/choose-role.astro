---
import Layout from "../layouts/Layout.astro";

// Shown after every delegate login while the demo session has no role yet
// (loadRolesOnLogin: false). Choosing a role writes it onto the session and
// updates person_segment for API gating.
const session = Astro.locals.session;
if (!session) return Astro.redirect("/login");
---

<Layout title="Choose your role">
  <div class="role-wrap">
    <div class="card role-card">
      <h1>Welcome{session.email ? `, ${session.email}` : ""}!</h1>

      <p class="muted">
        You're signed in through <strong>delegate</strong> and recognized as
        <code>person_id {session.personId}</code>. Pick how you'd like to use
        this demo session — VIP or Admin. Logout clears the session, so the
        next login will ask again.
      </p>

      <div class="buttons">
        <form method="post" action="/auth/role">
          <input type="hidden" name="role" value="vip" />
          <button class="btn btn-primary" type="submit">Join as VIP</button>
          <p class="who">Access the VIP Lounge and VIP-only sets</p>
        </form>

        <form method="post" action="/auth/role">
          <input type="hidden" name="role" value="admin" />
          <button class="btn btn-primary admin" type="submit">Join as Admin</button>
          <p class="who">Manage artists, schedule, tickets, and people</p>
        </form>
      </div>
    </div>
  </div>
</Layout>

<style>
  .role-wrap { display: flex; justify-content: center; padding-top: 2rem; }
  .role-card { max-width: 30rem; }
  .buttons { display: grid; gap: 1rem; margin-top: 1.5rem; }
  .buttons form { margin: 0; }
  .buttons .btn { width: 100%; }
  .btn.admin { background: linear-gradient(120deg, #10b981, #34d399); }
  .who { font-size: 0.8rem; color: var(--muted); margin: 0.4rem 0 0; text-align: center; }
  code { background: var(--surface-2); padding: 0.1rem 0.35rem; border-radius: 4px; }
</style>
