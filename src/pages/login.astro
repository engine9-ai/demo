---
import Layout from "../layouts/Layout.astro";
import { delegateAuth } from "../lib/engine9";
import { primaryRole } from "../lib/session";

const required = Astro.url.searchParams.get("required");
const errorMessage = Astro.url.searchParams.get("message");
const errorReason = Astro.url.searchParams.get("error");
const errorKind = Astro.url.searchParams.get("kind");
const errorDetail = Astro.url.searchParams.get("detail");
const continueUrl = Astro.url.searchParams.get("continue");
const session = Astro.locals.session;

// Core builds the delegate login URL; the browser comes back to
// /auth/delegate with a one-time code or signed bridge. prompt=consent
// forces a button click on Delegate even when already logged in there.
const loginUrl = delegateAuth().loginUrl({
  returnTo: new URL("/auth/delegate", Astro.url.origin).toString(),
  prompt: "consent",
});
---

<Layout title="Log in">
  <div class="login-wrap">
    <div class="card login-card">
      <h1>Log in</h1>

      {required && (
        <p class="notice">
          That page requires <strong>{required.toUpperCase()}</strong> access.
          Log in below to continue.
        </p>
      )}

      {continueUrl && (
        <p class="notice config">
          Local development needs one more browser step so Cloudflare’s bot
          check can run on the Delegate host.
        </p>
      )}

      {errorMessage && !continueUrl && (
        <p class={`notice error${errorKind === "configuration" ? " config" : ""}`}>
          {errorMessage}
          {(errorReason || errorDetail) && (
            <span class="operator-detail">
              {errorReason && (
                <>
                  Error code: <code>{errorReason}</code>
                </>
              )}
              {errorDetail && (
                <>
                  {errorReason && " · "}
                  Detail: <code>{errorDetail}</code>
                </>
              )}
            </span>
          )}
        </p>
      )}

      {continueUrl ? (
        <p class="muted">
          Your identity was verified, but this machine cannot call Delegate’s
          server exchange directly. Finish sign-in by opening Delegate in your
          browser:
        </p>
      ) : (
        <p class="muted">
          Authentication is handled by the shared <strong>delegate</strong>
          service. Delegate verifies who you are; this site then recognizes you
          as a <code>person_id</code> and applies your access from its own
          segments.
        </p>
      )}

      <div class="buttons">
        {continueUrl ? (
          <a class="btn btn-primary" href={continueUrl}>Continue sign-in on Delegate</a>
        ) : (
          <a class="btn btn-primary" href={loginUrl}>Sign in with Delegate</a>
        )}
      </div>

      {session && !continueUrl && (
        <p class="muted" style="margin-top: 1.5rem;">
          You're currently logged in as <strong>{primaryRole(session).toUpperCase()}</strong>
          (person_id {session.personId}). Signing in again re-verifies with delegate.
        </p>
      )}
    </div>
  </div>
</Layout>

<style>
  .login-wrap { display: flex; justify-content: center; padding-top: 2rem; }
  .login-card { max-width: 30rem; }
  .notice {
    background: rgba(244, 114, 182, 0.12);
    border: 1px solid rgba(244, 114, 182, 0.4);
    border-radius: 8px;
    padding: 0.6rem 0.9rem;
  }
  .notice.error {
    background: rgba(248, 113, 113, 0.12);
    border-color: rgba(248, 113, 113, 0.4);
  }
  .notice.error.config, .notice.config {
    background: rgba(251, 191, 36, 0.12);
    border-color: rgba(251, 191, 36, 0.45);
  }
  .operator-detail {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted, #94a3b8);
  }
  .buttons { display: grid; gap: 1rem; margin-top: 1.5rem; }
  .buttons .btn { width: 100%; text-align: center; }
  code { background: var(--surface-2); padding: 0.1rem 0.35rem; border-radius: 4px; }
</style>
