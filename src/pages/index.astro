---
import Layout from "../layouts/Layout.astro";
import { getDB, formatPrice, type Artist, type TicketType } from "../lib/db";

const db = getDB();
const { results: artists } = await db
  .prepare("SELECT * FROM artist ORDER BY id")
  .all<Artist>();
const { results: ticketTypes } = await db
  .prepare("SELECT * FROM ticket_type ORDER BY price_cents")
  .all<TicketType>();
---

<Layout title="Home">
  <section class="hero">
    <p class="kicker">July 18–19, 2026 · Crescent Bay Waterfront</p>
    <h1><span class="gradient-text">Solstice Wave</span><br />Two days. Five acts. One shoreline.</h1>
    <p class="lede">
      A pocket-sized pop festival on the water: {artists.length} headline-calibre acts
      across the Main Stage and the Lagoon Stage, plus a VIP Lounge with
      soundchecks and meet-and-greets you won't find on the public schedule.
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href="/tickets">Get tickets</a>
      <a class="btn btn-ghost" href="/schedule">See the schedule</a>
    </div>
  </section>

  <h2>The lineup</h2>
  <div class="grid grid-3">
    {artists.map((a) => (
      <div class="card artist-card" style={`--artist: ${a.color}`}>
        <div class="artist-emoji">{a.emoji}</div>
        <h3>{a.name}</h3>
        <p class="genre">{a.genre}</p>
      </div>
    ))}
  </div>
  <p><a href="/lineup">Read the full artist bios →</a></p>

  <h2>Tickets</h2>
  <div class="grid grid-2">
    {ticketTypes.map((t) => (
      <div class="card">
        <h3>{t.name} — {formatPrice(t.price_cents)}</h3>
        <p class="muted">{t.description}</p>
      </div>
    ))}
  </div>
</Layout>

<style>
  .hero { padding: 3rem 0 2rem; }
  .kicker {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.85rem;
    color: var(--accent);
    margin: 0 0 0.75rem;
  }
  .lede { font-size: 1.15rem; color: var(--muted); max-width: 42rem; }
  .cta-row { display: flex; gap: 0.75rem; margin-top: 1.5rem; flex-wrap: wrap; }

  .artist-card { border-top: 3px solid var(--artist); }
  .artist-card h3 { margin: 0.5rem 0 0.2rem; }
  .artist-emoji { font-size: 2rem; }
  .genre { color: var(--artist); font-weight: 700; font-size: 0.85rem; margin: 0; }
</style>
