---
import Layout from "../../layouts/Layout.astro";
import { getDB } from "../../lib/db";

const db = getDB();
const { results: people } = await db
  .prepare(
    `SELECT p.id AS person_id,
            trim(p.given_name || ' ' || p.family_name) AS name,
            pe.email,
            p.created_at
     FROM person p
     LEFT JOIN person_email pe ON pe.person_id = p.id
     ORDER BY p.id, pe.preference_order`
  )
  .all<{ person_id: number; name: string; email: string | null; created_at: string }>();
---

<Layout title="Admin · People">
  <p class="kicker">Admin only · gated server-side</p>
  <h1>Registered <span class="gradient-text">people</span></h1>
  <p class="muted">
    Everyone in the <code>person</code> table, joined to <code>person_email</code>.
    New sign-ups from <a href="/register">/register</a> flow through
    <code>POST /api/people</code>.
  </p>

  <div class="card" style="margin-top: 1.5rem; overflow-x: auto;">
    <table>
      <thead>
        <tr>
          <th>person_id</th>
          <th>Name</th>
          <th>Email</th>
          <th>Created</th>
        </tr>
      </thead>
      <tbody>
        {people.length === 0 ? (
          <tr><td colspan="4" class="muted">No people yet.</td></tr>
        ) : (
          people.map((row) => (
            <tr>
              <td>{row.person_id}</td>
              <td>{row.name}</td>
              <td>{row.email ?? <span class="muted">—</span>}</td>
              <td>{row.created_at}</td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>

  <p class="muted" style="margin-top: 1rem;">{people.length} row{people.length === 1 ? "" : "s"} (one per email when multiple exist).</p>
  <p><a href="/admin">← Back to admin</a></p>
</Layout>

<style>
  .kicker {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.85rem;
    color: var(--admin);
    margin: 0 0 0.5rem;
  }
  code { background: var(--surface-2); padding: 0.1rem 0.35rem; border-radius: 4px; }
</style>
