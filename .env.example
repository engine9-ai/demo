# Local development secrets, loaded by `astro dev` / `wrangler dev`.
# Copy to `.env` (gitignored) and fill in. In production set these with:
#   wrangler secret put DELEGATE_SHARED_SECRET
#   wrangler secret put SESSION_SECRET

# Must match the delegate deployment's DELEGATE_SHARED_SECRET
# (comma-separated values there allow rotation).
DELEGATE_SHARED_SECRET="dev-shared-secret"

# HMAC key that signs this site's session cookie. Generate with:
#   openssl rand -hex 32
SESSION_SECRET="dev-festival-session-secret"

# Required for local development (overrides the wrangler var). Calling
# production https://delegate.engine9.ai from astro dev fails on
# POST /handoff/exchange — Cloudflare Bot Fight challenges non-browser POSTs.
DELEGATE_URL="http://localhost:8787"
